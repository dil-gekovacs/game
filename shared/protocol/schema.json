{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game/shared/protocol/schema.json",
  "title": "Game WebSocket Protocol",
  "description": "JSON Schema for all client↔server WebSocket messages. This is the canonical language-agnostic reference. TypeScript consumers use shared/protocol/messages.ts directly; Go consumers validate/generate from this schema. See INTEGRATION_CONTRACT.md §4 for binary migration plan.",
  "$defs": {
    "EntityId": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535,
      "description": "u16 in binary"
    },
    "Tick": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295,
      "description": "u32 server simulation tick"
    },
    "Facing": {
      "type": "integer",
      "enum": [0, 1, 2, 3],
      "description": "0=Down 1=Up 2=Left 3=Right. 2 bits in binary."
    },
    "EntityState": {
      "type": "integer",
      "enum": [0, 1, 2, 3, 4, 5, 6],
      "description": "0=Idle 1=Moving 2=Attacking 3=Parrying 4=Stunned 5=Dead 6=Casting. u8 in binary."
    },
    "EntityType": {
      "type": "integer",
      "enum": [0, 1, 2, 3],
      "description": "0=Player 1=Enemy 2=Projectile 3=Item. u8 in binary."
    },
    "EventType": {
      "type": "integer",
      "enum": [0, 1, 2, 3, 4, 5, 6, 7, 8],
      "description": "0=Damage 1=Heal 2=ParrySuccess 3=ParryFail 4=EntitySpawn 5=EntityDespawn 6=ItemPickup 7=AbilityUsed 8=RoomTransition. u8 in binary."
    },
    "EntitySnapshot": {
      "type": "object",
      "description": "Full entity state. Binary: 24 bytes (see entities.ts for layout).",
      "required": ["id", "type", "state", "facing", "hp", "maxHp", "animFrame", "x", "y", "vx", "vy", "flags"],
      "additionalProperties": false,
      "properties": {
        "id":        { "$ref": "#/$defs/EntityId" },
        "type":      { "$ref": "#/$defs/EntityType" },
        "state":     { "$ref": "#/$defs/EntityState" },
        "facing":    { "$ref": "#/$defs/Facing" },
        "hp":        { "type": "integer", "minimum": 0, "maximum": 255 },
        "maxHp":     { "type": "integer", "minimum": 0, "maximum": 255 },
        "animFrame": { "type": "integer", "minimum": 0, "maximum": 255 },
        "x":         { "type": "integer", "minimum": -32768, "maximum": 32767, "description": "World x in tile units. i16 in binary." },
        "y":         { "type": "integer", "minimum": -32768, "maximum": 32767, "description": "World y in tile units. i16 in binary." },
        "vx":        { "type": "integer", "minimum": -32768, "maximum": 32767, "description": "Velocity x ×100. i16 in binary." },
        "vy":        { "type": "integer", "minimum": -32768, "maximum": 32767, "description": "Velocity y ×100. i16 in binary." },
        "flags":     { "type": "integer", "minimum": 0, "maximum": 255, "description": "Bit 0: visible. Bit 1: invincible. Bits 2-7: reserved." }
      }
    },
    "EntityDelta": {
      "type": "object",
      "description": "Partial entity update. Only id is required; other fields present only if changed. Binary: u16 presence bitmask precedes optional fields.",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id":        { "$ref": "#/$defs/EntityId" },
        "type":      { "$ref": "#/$defs/EntityType" },
        "state":     { "$ref": "#/$defs/EntityState" },
        "facing":    { "$ref": "#/$defs/Facing" },
        "hp":        { "type": "integer", "minimum": 0, "maximum": 255 },
        "maxHp":     { "type": "integer", "minimum": 0, "maximum": 255 },
        "animFrame": { "type": "integer", "minimum": 0, "maximum": 255 },
        "x":         { "type": "integer", "minimum": -32768, "maximum": 32767 },
        "y":         { "type": "integer", "minimum": -32768, "maximum": 32767 },
        "vx":        { "type": "integer", "minimum": -32768, "maximum": 32767 },
        "vy":        { "type": "integer", "minimum": -32768, "maximum": 32767 },
        "flags":     { "type": "integer", "minimum": 0, "maximum": 255 }
      }
    }
  },
  "oneOf": [
    {
      "title": "PlayerInput",
      "description": "Client→Server. Binary opcode 0x01. 10 bytes.",
      "type": "object",
      "required": ["type", "seq", "tick", "moveX", "moveY", "primary", "secondary", "parry", "aimAngle"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "PlayerInput" },
        "seq":       { "type": "integer", "minimum": 0, "maximum": 65535, "description": "Monotonic input counter. u16 in binary." },
        "tick":      { "$ref": "#/$defs/Tick" },
        "moveX":     { "type": "number", "minimum": -1.0, "maximum": 1.0, "description": "Float in JSON. i8 ÷ 127 in binary." },
        "moveY":     { "type": "number", "minimum": -1.0, "maximum": 1.0, "description": "Float in JSON. i8 ÷ 127 in binary." },
        "primary":   { "type": "boolean", "description": "Bit 0 of buttons byte in binary." },
        "secondary": { "type": "boolean", "description": "Bit 1 of buttons byte in binary." },
        "parry":     { "type": "boolean", "description": "Bit 2 of buttons byte in binary." },
        "aimAngle":  { "type": "number", "minimum": 0, "maximum": 6.2832, "description": "Radians [0, 2π]. u8 ÷ 255 × 2π in binary." }
      }
    },
    {
      "title": "AbilitySwap",
      "description": "Client→Server. Binary opcode 0x02. 4 bytes.",
      "type": "object",
      "required": ["type", "slotIndex", "itemId"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "AbilitySwap" },
        "slotIndex": { "type": "integer", "minimum": 0, "maximum": 3, "description": "u8 in binary." },
        "itemId":    { "type": "integer", "minimum": 0, "maximum": 65535, "description": "u16 in binary." }
      }
    },
    {
      "title": "Ping",
      "description": "Client→Server. Binary opcode 0x03. 9 bytes.",
      "type": "object",
      "required": ["type", "clientTimestamp"],
      "additionalProperties": false,
      "properties": {
        "type":            { "const": "Ping" },
        "clientTimestamp": { "type": "number", "description": "performance.now() ms. f64 in binary." }
      }
    },
    {
      "title": "WorldSnapshot",
      "description": "Server→Client. Binary opcode 0x10. Variable length.",
      "type": "object",
      "required": ["type", "tick", "ackSeq", "entities"],
      "additionalProperties": false,
      "properties": {
        "type":     { "const": "WorldSnapshot" },
        "tick":     { "$ref": "#/$defs/Tick" },
        "ackSeq":   { "type": "integer", "minimum": 0, "maximum": 65535, "description": "Last applied client input seq. u16 in binary." },
        "entities": {
          "type": "array",
          "items": { "$ref": "#/$defs/EntityDelta" },
          "description": "Delta entities since client's last ack'd snapshot."
        }
      }
    },
    {
      "title": "Event",
      "description": "Server→Client. Binary opcode 0x11. 10 bytes fixed.",
      "type": "object",
      "required": ["type", "tick", "eventType", "entityId"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "Event" },
        "tick":      { "$ref": "#/$defs/Tick" },
        "eventType": { "$ref": "#/$defs/EventType" },
        "entityId":  { "$ref": "#/$defs/EntityId" },
        "targetId":  { "$ref": "#/$defs/EntityId" },
        "value":     { "type": "integer", "minimum": -32768, "maximum": 32767, "description": "i16 in binary." }
      }
    },
    {
      "title": "Pong",
      "description": "Server→Client. Binary opcode 0x12. 17 bytes.",
      "type": "object",
      "required": ["type", "clientTimestamp", "serverTimestamp"],
      "additionalProperties": false,
      "properties": {
        "type":            { "const": "Pong" },
        "clientTimestamp": { "type": "number", "description": "Echoed from Ping. f64 in binary." },
        "serverTimestamp": { "type": "number", "description": "Server monotonic ms. f64 in binary." }
      }
    },
    {
      "title": "PlayerJoined",
      "description": "Server→Client broadcast. Binary opcode 0x13.",
      "type": "object",
      "required": ["type", "entityId", "playerId", "initialState"],
      "additionalProperties": false,
      "properties": {
        "type":         { "const": "PlayerJoined" },
        "entityId":     { "$ref": "#/$defs/EntityId" },
        "playerId":     { "type": "string", "format": "uuid", "description": "UUID. 16 raw bytes in binary." },
        "initialState": { "$ref": "#/$defs/EntitySnapshot" }
      }
    },
    {
      "title": "PlayerLeft",
      "description": "Server→Client broadcast. Binary opcode 0x14. 3 bytes.",
      "type": "object",
      "required": ["type", "entityId"],
      "additionalProperties": false,
      "properties": {
        "type":     { "const": "PlayerLeft" },
        "entityId": { "$ref": "#/$defs/EntityId" }
      }
    },
    {
      "title": "GameStart",
      "description": "Server→Client. Binary opcode 0x15. 5 bytes + mapId string.",
      "type": "object",
      "required": ["type", "serverTick", "mapId"],
      "additionalProperties": false,
      "properties": {
        "type":       { "const": "GameStart" },
        "serverTick": { "$ref": "#/$defs/Tick" },
        "mapId":      { "type": "string", "description": "Map asset identifier. Clients load this map before entering the game loop." }
      }
    },
    {
      "title": "GameOver",
      "description": "Server→Client. Binary opcode 0x16. 2 bytes.",
      "type": "object",
      "required": ["type", "victory"],
      "additionalProperties": false,
      "properties": {
        "type":    { "const": "GameOver" },
        "victory": { "type": "boolean", "description": "u8 (0/1) in binary." }
      }
    }
  ]
}
